---
import { Icon } from '@lucide/astro';

interface Props {
  title: string;
  iconName?: string;
  imageSrc?: string;
  href: string;
  splitLeftHref?: string;
  splitRightHref?: string;
  imageVariant?: string;
}

const { title, iconName, imageSrc, href, splitLeftHref, splitRightHref, imageVariant } = Astro.props;
const isExternal = /^https?:\/\//.test(href);
const hasSplit = Boolean(splitLeftHref && splitRightHref);
const imageVariantClass = imageVariant === 'large' ? 'card-image--large' : '';
---

<div class="card-wrap">
  <a
    href={href}
    class="card"
    {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    {hasSplit ? (
      <button
        type="button"
        class="split-corner-button"
        aria-label={`Abrir Flexway y ${title} en dos ventanas (75/25)`}
        data-split-left={splitLeftHref}
        data-split-right={splitRightHref}
      >
        ⇄
      </button>
    ) : null}
    <div class="card-icon">
      {imageSrc ? (
        <img src={imageSrc} alt={title} class={`card-image ${imageVariantClass}`} />
      ) : iconName ? (
        <Icon name={iconName} size={64} stroke-width={1.5} />
      ) : null}
    </div>
    <p class="card-title">{title}</p>
  </a>

  {hasSplit ? (
    <script is:inline>
      (() => {
        if (window.__openlinkSplitInit) return;
        window.__openlinkSplitInit = true;

        function qsWrap(el) {
          return el && el.closest ? el.closest('.card-wrap') : null;
        }

        function openPopoutForWrap(wrap) {
          if (!wrap) return;
          const openBtn = wrap.querySelector('.split-corner-button');
          if (!openBtn) return;

          const left = openBtn.getAttribute('data-split-left') || '';
          const right = openBtn.getAttribute('data-split-right') || '';
          if (!left || !right) return;

          const availW = window.screen?.availWidth ?? window.innerWidth;
          const availH = window.screen?.availHeight ?? window.innerHeight;
          const h = Math.max(500, availH);

          // Reparto de pantalla: Flexway (izq) 75%, Rossboard (der) 25%
          // Importante: aseguramos que la suma sea EXACTAMENTE availW para que no se solapen.
          const flexwayRatio = 0.75;
          const minFlexwayW = 700;
          const minRossboardW = 420;

          // Clamp de Flexway para dejar siempre espacio mínimo a Rossboard.
          const idealFlexwayW = Math.floor(availW * flexwayRatio);
          const maxFlexwayW = Math.max(minFlexwayW, availW - minRossboardW);
          const flexwayW = Math.min(maxFlexwayW, Math.max(minFlexwayW, idealFlexwayW));
          const rossboardW = Math.max(minRossboardW, availW - flexwayW);

          // Nota: para poder posicionar y dimensionar, abrimos primero `about:blank`
          // (ventana "real") y luego navegamos a la URL. Algunos navegadores ignoran
          // move/resize cuando se abre directamente a un dominio externo.
          const baseLeft = Number.isFinite(window.screen?.availLeft) ? window.screen.availLeft : 0;
          const baseTop = Number.isFinite(window.screen?.availTop) ? window.screen.availTop : 0;

          const commonFeatures = [
            'popup=yes',
            'resizable=yes',
            'scrollbars=yes',
            'toolbar=no',
            'menubar=no',
            'status=no',
          ].join(',');

          const leftWin = window.open(
            'about:blank',
            'split_left',
            `${commonFeatures},width=${flexwayW},height=${h},left=${baseLeft},top=${baseTop}`,
          );
          const rightWin = window.open(
            'about:blank',
            'split_right',
            `${commonFeatures},width=${rossboardW},height=${h},left=${baseLeft + flexwayW},top=${baseTop}`,
          );

          if (!leftWin || !rightWin) {
            alert(
              'El navegador ha bloqueado las ventanas emergentes.\n\n' +
                'Permite popups para este sitio y vuelve a pulsar el botón.\n' +
                'En Chrome/Edge suele aparecer un icono en la barra de direcciones.',
            );
            return;
          }

          try {
            leftWin?.moveTo(baseLeft, baseTop);
            leftWin?.resizeTo(flexwayW, h);
          } catch {}
          try {
            rightWin?.moveTo(baseLeft + flexwayW, baseTop);
            rightWin?.resizeTo(rossboardW, h);
          } catch {}

          // Navegar después de abrir (para preservar tamaño/posición).
          try {
            leftWin.location.href = left;
          } catch {}
          try {
            rightWin.location.href = right;
          } catch {}
        }

        document.addEventListener('click', (ev) => {
          const target = ev.target;
          if (!target) return;

          const openBtn = target.closest ? target.closest('.split-corner-button') : null;
          if (openBtn) {
            ev.preventDefault();
            ev.stopPropagation();
            openPopoutForWrap(qsWrap(openBtn));
          }
        });
      })();
    </script>
  ) : null}
 </div>

<style>
  .card-wrap {
    position: relative;
  }

  .card-icon {
    height: 90px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.8rem;
  }
  .card-image {
    max-width: 120px;
    max-height: 90px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .card-image--large {
    max-width: 170px;
    max-height: 130px;
  }
  .card:hover .card-icon {
    color: var(--header-accent);
  }

  .split-corner-button {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid var(--card-border);
    background: rgba(255, 255, 255, 0.92);
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    transition: transform var(--transition-speed), background var(--transition-speed);
  }
  .split-corner-button:hover {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 1);
  }

</style>
