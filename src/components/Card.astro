---
import { Icon } from '@lucide/astro';

interface Props {
  title: string;
  iconName?: string;
  imageSrc?: string;
  href: string;
  imageVariant?: string;
}

const { title, iconName, imageSrc, href, imageVariant } = Astro.props;
const isExternal = /^https?:\/\//.test(href);
const imageVariantClass = imageVariant === 'large' ? 'card-image--large' : '';
---

<div class="card-wrap">
  <a
    href={href}
    class="card"
    {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    <div class="card-icon">
      {imageSrc ? (
        <img src={imageSrc} alt={title} class={`card-image ${imageVariantClass}`} />
      ) : iconName ? (
        <Icon name={iconName} size={64} stroke-width={1.5} />
      ) : null}
    </div>
    <p class="card-title">{title}</p>
  </a>
</div>

<style>
  .card-wrap {
    position: relative;
  }

  .card-icon {
    height: 90px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.8rem;
  }
  .card-image {
    max-width: 120px;
    max-height: 90px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .card-image--large {
    max-width: 170px;
    max-height: 130px;
  }
  .card:hover .card-icon {
    color: var(--header-accent);
  }
</style>
