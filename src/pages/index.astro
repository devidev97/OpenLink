---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

type Tool = {
	title: string;
	href: string;
	imageSrc?: string;
	iconName?: string;
	imageVariant?: string;
	splitLeftHref?: string;
	splitRightHref?: string;
};

function parseExtraLinks(raw: string | undefined): Tool[] {
	if (!raw) return [];
	try {
		const trimmed = raw.trim();
		const unquoted =
			(trimmed.startsWith('"') && trimmed.endsWith('"')) ||
			(trimmed.startsWith("'") && trimmed.endsWith("'"))
				? trimmed.slice(1, -1)
				: trimmed;
		const parsed = JSON.parse(unquoted);
		if (!Array.isArray(parsed)) return [];
		return parsed
			.map((item) => {
				if (!item || typeof item !== 'object') return null;
				const title = (item as any).title;
				const href = (item as any).href;
				const imageSrcRaw = (item as any).imageSrc;
				const imageVariant = (item as any).imageVariant;
				if (typeof title !== 'string' || typeof href !== 'string') return null;

				const imageSrc =
					typeof imageSrcRaw === 'string' && imageSrcRaw.trim().length > 0
						? imageSrcRaw
						: '/logo-link.svg';

				return {
					title,
					href,
					imageSrc,
					...(typeof imageVariant === 'string' ? { imageVariant } : {}),
				} satisfies Tool;
			})
			.filter(Boolean) as Tool[];
	} catch {
		return [];
	}
}

const tools = parseExtraLinks(import.meta.env.PUBLIC_EXTRA_LINKS);

const flexwayHref =
	tools.find((t) => /frsiberiagroup\.flexways\.net/i.test(t.href))?.href ??
	tools.find((t) => /^flexway$/i.test(t.title))?.href ??
	'https://frsiberiagroup.flexways.net/web/booking/#/login';

const rossboardHref =
	tools.find((t) => /board\.devidev\.work/i.test(t.href))?.href ??
	tools.find((t) => /^rossboard$/i.test(t.title))?.href ??
	'https://board.devidev.work/';

const toolsWithSplit: Tool[] = tools.map((t) => {
	const isRossboard =
		t.href === rossboardHref || /board\.devidev\.work/i.test(t.href) || /^rossboard$/i.test(t.title);

	if (!isRossboard) return t;

	return {
		...t,
		splitLeftHref: flexwayHref,
		splitRightHref: rossboardHref,
	};
});
---

<Layout title="Dashboard Tools">
	<div class="dashboard-grid">
		{toolsWithSplit.map((tool) => (
			<Card {...tool} />
		))}
	</div>
</Layout>
