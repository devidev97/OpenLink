## Opcional: hosts permitidos para Vite (dev/preview), separados por coma.
## Si no se define, se usan los valores por defecto en allowed-hosts.mjs
# ALLOWED_HOSTS=links.devidev.work,dfds.devidev.app

## Links extra (si no pones imagen, se usa /public/logo-link.svg)
## Multilínea permitido si va ENTRE COMILLAS:
PUBLIC_EXTRA_LINKS='[
  {
    "title": "Flexway",
    "href": "https://example.com",
    "imageSrc": "/logo-link.svg"
  }
]'

